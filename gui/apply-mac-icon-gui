    # ── Settings callbacks ───────────────────────────────────────────────
    def _on_theme(self, theme):
        self.settings.setValue("appearance/theme", theme)
        self._apply_style()
        self.update()

    def _on_glass(self, on):
        self.settings.setValue("appearance/glass", on)
        self.setAttribute(Qt.WidgetAttribute.WA_TranslucentBackground, on)
        self._apply_style()
        self.update()

    def _browse_source(self):
        d = QFileDialog.getExistingDirectory(self, "Select Source Folder", self.source_input.text())
        if d:
            self.source_input.setText(d)
            self.settings.setValue("source/folder", d)
            self._rescan_source()

    def _on_source_change(self):
        path = self.source_input.text()
        self.settings.setValue("source/folder", path)
        self._rescan_source()

    def _rescan_source(self):
        folder = self.source_input.text()
        new_files = []
        if os.path.isdir(folder):
            for f in sorted(os.listdir(folder)):
                if os.path.splitext(f)[1].lower() in ICON_EXTENSIONS:
                    new_files.append(os.path.join(folder, f))
        self.icon_files = new_files
        self.file_list.clear()
        for fp in self.icon_files:
            item = QListWidgetItem(os.path.basename(fp))
            item.setData(Qt.ItemDataRole.UserRole, fp)
            ext = os.path.splitext(fp)[1].lower()
            if ext == ".png":
                pix = QPixmap(fp)
                if not pix.isNull():
                    item.setIcon(QIcon(pix.scaled(28, 28, Qt.AspectRatioMode.KeepAspectRatio,
                                                   Qt.TransformationMode.SmoothTransformation)))
            else:
                ti = QIcon.fromTheme("image-x-generic")
                if not ti.isNull():
                    item.setIcon(QIcon(ti.pixmap(28, 28)))
            self.file_list.addItem(item)
        if self.file_list.count() > 0:
            self.file_list.setCurrentRow(0)
            self.preview_label.setText("Select an icon")
            self.info_label.setText("")
            self.meta_label.setText("")

    def _restore_backup(self):
        backup_dir = os.path.expanduser("~/.local/share/macosicons/backups")
        if not os.path.isdir(backup_dir):
            self._restore_status.setText("No backups found")
            QTimer.singleShot(2000, lambda: self._restore_status.setText(""))
            return
        backups = sorted(
            [f for f in os.listdir(backup_dir) if ".backup." in f],
            key=lambda f: os.path.getmtime(os.path.join(backup_dir, f)),
            reverse=True,
        )
        if not backups:
            self._restore_status.setText("No backups found")
            QTimer.singleShot(2000, lambda: self._restore_status.setText(""))
            return
        from PyQt6.QtWidgets import QInputDialog
        choice, ok = QInputDialog.getItem(self, "Restore Backup", "Select backup to restore:", backups, 0, False)
        if ok and choice:
            src = os.path.join(backup_dir, choice)
            desktop_name = choice.split(".backup.")[0]
            dest_dir = os.path.expanduser("~/.local/share/applications")
            dest = os.path.join(dest_dir, desktop_name)
            try:
                shutil.copy2(src, dest)
                for cmd in (["kbuildsycoca6"], ["kbuildsycoca5"]):
                    try:
                        subprocess.run(cmd, capture_output=True, timeout=10)
                        break
                    except Exception:
                        continue
                self._restore_status.setText("Restored!")
                QTimer.singleShot(2000, lambda: self._restore_status.setText(""))
            except Exception as e:
                self._restore_status.setText(f"Failed: {e}")
                QTimer.singleShot(3000, lambda: self._restore_status.setText(""))

    def _force_refresh(self):
        cmds = [
            ["kbuildsycoca6"],
            ["kbuildsycoca5"],
        ]
        for cmd in cmds:
            try:
                subprocess.run(cmd, capture_output=True, timeout=10)
                break
            except Exception:
                continue
        for p in ("~/.icons", "~/.local/share/icons"):
            ep = os.path.expanduser(p)
            if os.path.isdir(ep):
                try:
                    subprocess.run(["gtk-update-icon-cache", "-f", "-t", ep], capture_output=True, timeout=10)
                except Exception:
                    pass
        self._refresh_status.setText("Refreshed!")
        QTimer.singleShot(2000, lambda: self._refresh_status.setText(""))

    # ── Style ────────────────────────────────────────────────────────────
    def _apply_style(self):
        theme = self.settings.value("appearance/theme", "system", type=str)
        glass = self.settings.value("appearance/glass", True, type=bool)
        if theme == "dark":
            dm = True
        elif theme == "light":
            dm = False
        else:
            dm = None
        self.setStyleSheet(build_stylesheet(dark_mode=dm, glass_enabled=glass))

    # ── Map tab callbacks ────────────────────────────────────────────────
    def _on_file_select(self, current, previous):
        if not current:
            return
        fp = current.data(Qt.ItemDataRole.UserRole)
        if not fp or not os.path.isfile(fp):
            return
        if self._preview_tmpdir:
            shutil.rmtree(self._preview_tmpdir, ignore_errors=True)
            self._preview_tmpdir = None
        self.info_label.setText(os.path.basename(fp))
        size = os.path.getsize(fp)
        self.meta_label.setText(f"{size / 1024:.0f} KB" if size < 1048576 else f"{size / 1048576:.1f} MB")
        preview = extract_preview(fp)
        if preview:
            pix = QPixmap(preview)
            if not pix.isNull():
                scaled = pix.scaled(180, 180, Qt.AspectRatioMode.KeepAspectRatio,
                                    Qt.TransformationMode.SmoothTransformation)
                self.preview_label.setPixmap(make_rounded_pixmap(scaled, radius=22))
                self._preview_tmpdir = os.path.dirname(preview)
                if self._preview_tmpdir == os.path.dirname(fp):
                    self._preview_tmpdir = None
        else:
            self.preview_label.setText("No preview")

    def _filter_files(self, text):
        for i in range(self.file_list.count()):
            item = self.file_list.item(i)
            item.setHidden(text.lower() not in item.text().lower())

    def _filter_apps(self, text):
        for i in range(self.app_list.count()):
            item = self.app_list.item(i)
            item.setHidden(text.lower() not in item.text().lower())

    def _accept(self):
        fi = self.file_list.currentItem()
        ai = self.app_list.currentItem()
        if fi and ai:
            self.selected_file = fi.data(Qt.ItemDataRole.UserRole)
            self.selected_app = ai.text()
            self.close()

    # ── Paint ────────────────────────────────────────────────────────────
    def paintEvent(self, event):
        glass = self.settings.value("appearance/glass", True, type=bool)
        p = QPainter(self)
        p.setRenderHint(QPainter.RenderHint.Antialiasing)
        w, h = self.width(), self.height()

        if not glass:
            theme = self.settings.value("appearance/theme", "system", type=str)
            if theme == "dark":
                bg = QColor(28, 28, 30)
            elif theme == "light":
                bg = QColor(242, 242, 247)
            else:
                wc = QApplication.palette().color(QApplication.palette().ColorRole.Window)
                lum = 0.299 * wc.redF() + 0.587 * wc.greenF() + 0.114 * wc.blueF()
                bg = QColor(28, 28, 30) if lum < 0.5 else QColor(242, 242, 247)
            p.fillRect(0, 0, w, h, bg)
        else:
            theme = self.settings.value("appearance/theme", "system", type=str)
            if theme == "dark":
                dark = True
            elif theme == "light":
                dark = False
            else:
                wc = QApplication.palette().color(QApplication.palette().ColorRole.Window)
                lum = 0.299 * wc.redF() + 0.587 * wc.greenF() + 0.114 * wc.blueF()
                dark = lum < 0.5
            if dark:
                tint = QColor(0, 0, 0, 35)
                spec_top = QColor(255, 255, 255, 10)
            else:
                tint = QColor(255, 255, 255, 30)
                spec_top = QColor(255, 255, 255, 15)
            p.fillRect(0, 0, w, h, tint)
            spec = QLinearGradient(0, 0, 0, min(30, h // 4))
            spec.setColorAt(0, spec_top)
            spec.setColorAt(1, QColor(0, 0, 0, 0))
            p.fillRect(0, 0, w, min(30, h // 4), spec)

        p.end()

    def closeEvent(self, event):
        if self._preview_tmpdir:
            shutil.rmtree(self._preview_tmpdir, ignore_errors=True)
        super().closeEvent(event)


