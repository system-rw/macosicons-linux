#!/bin/bash

# ── Config ───────────────────────────────────────────────────────────────
CONFIG_DIR="$HOME/.config/macOSicons"
CONFIG_FILE="$CONFIG_DIR/macOSicons.conf"
BACKUP_DIR="$HOME/.local/share/macosicons/backups"
TARGET_DIR="$HOME/Pictures/MacIcons"
mkdir -p "$TARGET_DIR" "$CONFIG_DIR" "$BACKUP_DIR"

# Read config value (compatible with QSettings INI format)
cfg_get() {
    local key="$1" default="$2"
    if [ -f "$CONFIG_FILE" ]; then
        local val
        val=$(grep -E "^${key}=" "$CONFIG_FILE" 2>/dev/null | head -1 | cut -d= -f2-)
        if [ -n "$val" ]; then
            echo "$val"
            return
        fi
    fi
    echo "$default"
}

cfg_set() {
    local key="$1" val="$2"
    mkdir -p "$CONFIG_DIR"
    if [ -f "$CONFIG_FILE" ] && grep -qE "^${key}=" "$CONFIG_FILE" 2>/dev/null; then
        sed -i "s|^${key}=.*|${key}=${val}|" "$CONFIG_FILE"
    else
        echo "${key}=${val}" >> "$CONFIG_FILE"
    fi
}

DOWNLOADS_DIR=$(cfg_get "source/folder" "$HOME/Downloads")
BACKUP_ENABLED=$(cfg_get "backups/enabled" "false")

# ── Helper: safe cleanup ─────────────────────────────────────────────────
safe_cleanup() {
    local dir="$1"
    case "$dir" in
        /tmp/*) cd "$HOME" 2>/dev/null || true; rm -rf "$dir" ;;
        *) echo "Refusing to remove $dir — not in /tmp" >&2 ;;
    esac
}

# ── Helper: force icon refresh ───────────────────────────────────────────
do_refresh() {
    echo "🔄 Refreshing icon caches..."
    kbuildsycoca6 2>/dev/null || kbuildsycoca5 2>/dev/null
    for p in ~/.icons ~/.local/share/icons; do
        [ -d "$p" ] && gtk-update-icon-cache -f -t "$p" 2>/dev/null
    done
    echo "✅ Icon caches refreshed."
}

# ── Helper: list backups ─────────────────────────────────────────────────
do_restore() {
    if [ ! -d "$BACKUP_DIR" ]; then
        echo "❌ No backups directory found."
        exit 1
    fi
    mapfile -t backups < <(find "$BACKUP_DIR" -maxdepth 1 -name "*.backup.*" -printf "%f\n" 2>/dev/null | sort -r)
    if [ ${#backups[@]} -eq 0 ]; then
        echo "❌ No backups found in $BACKUP_DIR"
        exit 1
    fi
    echo "📋 Available backups:"
    selected=$(printf '%s\n' "${backups[@]}" | fzf --height 40% --reverse --prompt="Restore > ")
    if [ -z "$selected" ]; then
        echo "Cancelled."
        exit 0
    fi
    desktop_name="${selected%%.backup.*}"
    src="$BACKUP_DIR/$selected"
    dest="$HOME/.local/share/applications/$desktop_name"
    cp "$src" "$dest"
    echo "✅ Restored $desktop_name from backup."
    do_refresh
}

# ── Helper: interactive settings ─────────────────────────────────────────
do_settings() {
    echo ""
    echo "═══ macOSicons Settings ═══"
    echo ""
    echo "  1) Source Folder    : $DOWNLOADS_DIR"
    echo "  2) Auto Backups     : $BACKUP_ENABLED"
    echo "  3) Force Refresh"
    echo "  4) Restore Backup"
    echo "  5) Done"
    echo ""
    read -rp "  Choose [1-5]: " choice
    case "$choice" in
        1)
            read -rp "  Enter new source folder: " new_path
            if [ -d "$new_path" ]; then
                cfg_set "source/folder" "$new_path"
                DOWNLOADS_DIR="$new_path"
                echo "  ✅ Source folder updated."
            else
                echo "  ❌ Directory does not exist."
            fi
            do_settings
            ;;
        2)
            if [ "$BACKUP_ENABLED" = "true" ]; then
                cfg_set "backups/enabled" "false"
                BACKUP_ENABLED="false"
                echo "  ✅ Automatic backups disabled."
            else
                cfg_set "backups/enabled" "true"
                BACKUP_ENABLED="true"
                echo "  ✅ Automatic backups enabled."
            fi
            do_settings
            ;;
        3) do_refresh; do_settings ;;
        4) do_restore; do_settings ;;
        5) echo "Done." ;;
        *) echo "  Invalid choice."; do_settings ;;
    esac
}

# ── Parse flags ──────────────────────────────────────────────────────────
case "${1:-}" in
    --settings)  do_settings; exit 0 ;;
    --restore)   do_restore; exit 0 ;;
    --refresh)   do_refresh; exit 0 ;;
    --help|-h)
        echo "Usage: apply-mac-icon [OPTION]"
        echo ""
        echo "Options:"
        echo "  (none)       Launch the interactive icon mapper"
        echo "  --settings   Configure source folder, backups, etc."
        echo "  --restore    Restore a .desktop file from backup"
        echo "  --refresh    Force refresh icon caches"
        echo "  --help       Show this help"
        exit 0
        ;;
esac

# ── Main: interactive icon mapper ────────────────────────────────────────
cd "$DOWNLOADS_DIR" || { echo "❌ Source folder not found: $DOWNLOADS_DIR"; exit 1; }
# Support .icns and .png
ICNS_FILES=(*.icns *.png)

if [ ! -e "${ICNS_FILES[0]}" ]; then
    echo "❌ No icon files (.icns, .png) found in $DOWNLOADS_DIR"
    exit 1
fi

echo "Select the icon file you want to use:"
ls -1t *.icns *.png 2>/dev/null | fzf --height 40% --reverse > /tmp/selected_icns.txt
SELECTED_ICNS=$(cat /tmp/selected_icns.txt)

if [ -z "$SELECTED_ICNS" ]; then
    echo "Cancelled."
    exit 0
fi

echo "🔍 Select the app you want to map this icon to:"
find /usr/share/applications $HOME/.local/share/applications -name "*.desktop" 2>/dev/null | \
    awk -F'/' '{print $NF}' | sort -u | fzf --height 50% --reverse > /tmp/selected_app.txt

SELECTED_APP=$(cat /tmp/selected_app.txt)

if [ -z "$SELECTED_APP" ]; then
    echo "Cancelled."
    exit 0
fi

# Clean app name for filename
APP_CLEAN_NAME=$(basename "$SELECTED_APP" .desktop)
PNG_OUTPUT="$TARGET_DIR/${APP_CLEAN_NAME}.png"

# Create isolated workspace
WORK_DIR=$(mktemp -d)
cp "$DOWNLOADS_DIR/$SELECTED_ICNS" "$WORK_DIR/source_file"

FILE_EXT="${SELECTED_ICNS##*.}"
FILE_EXT=$(echo "$FILE_EXT" | tr '[:upper:]' '[:lower:]')

case "$FILE_EXT" in
    icns)
        echo "🚀 Extracting image assets safely..."
        (cd "$WORK_DIR" && icns2png -x source_file) > /dev/null 2>&1
        EXTRACTED_FILE=$(find "$WORK_DIR" -maxdepth 1 \( -name '*1024x1024*.png' -o -name '*512x512*.png' \) 2>/dev/null | head -n 1)
        if [ -z "$EXTRACTED_FILE" ]; then
            EXTRACTED_FILE=$(ls -S "$WORK_DIR"/*.png 2>/dev/null | head -n 1)
        fi
        if [ -f "$EXTRACTED_FILE" ]; then
            echo "📐 Applying the icon..."
            magick "$EXTRACTED_FILE" -fuzz 10% -trim +repage -resize 512x512 -background none -gravity center -extent 512x512 "$PNG_OUTPUT"
        else
            echo "❌ Extraction failed! Could not extract a valid PNG from this .icns file."
            safe_cleanup "$WORK_DIR"
            exit 1
        fi
        ;;
    png)
        echo "📐 Applying the icon..."
        magick "$WORK_DIR/source_file" -fuzz 10% -trim +repage -resize 512x512 -background none -gravity center -extent 512x512 "$PNG_OUTPUT" 2>/dev/null
        if [ ! -f "$PNG_OUTPUT" ]; then
            echo "❌ Could not process this PNG file."
            safe_cleanup "$WORK_DIR"
            exit 1
        fi
        ;;
    *)
        echo "❌ Unsupported file type: .$FILE_EXT"
        safe_cleanup "$WORK_DIR"
        exit 1
        ;;
esac

safe_cleanup "$WORK_DIR"
echo "✅ Icon saved as: $PNG_OUTPUT"

# Overwrite user local app config
APP_PATH=$(find /usr/share/applications $HOME/.local/share/applications -name "$SELECTED_APP" | head -n 1)
USER_APP_DIR="$HOME/.local/share/applications"
mkdir -p "$USER_APP_DIR"

# Backup if enabled
if [ "$BACKUP_ENABLED" = "true" ]; then
    if [ -f "$APP_PATH" ]; then
        cp "$APP_PATH" "$BACKUP_DIR/$(basename "$SELECTED_APP").backup.$(date +%Y%m%d%H%M%S)"
        echo "📦 Backup saved."
    fi
fi

cp "$APP_PATH" "$USER_APP_DIR/$SELECTED_APP"
sed -i "s|^Icon=.*|Icon=$PNG_OUTPUT|" "$USER_APP_DIR/$SELECTED_APP"

echo "🎉 Success! Custom icon fully assigned to $SELECTED_APP"
do_refresh
